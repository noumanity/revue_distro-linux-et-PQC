% beamerthemeNoumanity.sty - Theme Beamer Noumanity, extension de metropolis
% Couleurs : branding.yml (orange #FA4D1F, noir #000000)
% Polices  : ABeeZee (titres) + Arimo (corps) si installes ; repli Latin Modern.
% Conforme ADR-001 : base metropolis, fontspec, LuaLaTeX.
\mode<presentation>

% Charger metropolis comme base
\usetheme{metropolis}

% Valeurs par defaut si theme.generated.tex n'est pas charge
\providecolor{NoumanityOrange}{HTML}{FA4D1F}
\providecolor{NoumanityBlack}{HTML}{000000}
\providecolor{NoumanityWhite}{HTML}{FFFFFF}
\providecolor{NouThemeFrametitleFg}{HTML}{000000}
\providecolor{NouThemeProgressBarBg}{HTML}{C0C0C0}
\providecolor{NouThemeSubitemFg}{HTML}{FA8A70}
\providecolor{NouThemeBlockBodyBg}{HTML}{F2F2F2}
\providecommand{\NouThemeBodyFont}{Arimo}
\providecommand{\NouThemeBodyBoldFont}{Arimo Bold}
\providecommand{\NouThemeBodyItalicFont}{Arimo Italic}
\providecommand{\NouThemeBodyBoldItalicFont}{Arimo Bold Italic}
\providecommand{\NouThemeTitleFont}{ABeeZee}
\providecommand{\NouThemeTitleSize}{\Large}
\providecommand{\NouThemeFrameTitleSize}{\large}
\providecommand{\NouThemeItemSymbol}{\textbullet}
\providecommand{\NouThemeSubitemSymbol}{\textendash}

% Surcharge de la palette metropolis
\setbeamercolor{frametitle}{bg=, fg=NouThemeFrametitleFg}
\setbeamercolor{progress bar}{fg=NoumanityOrange, bg=NouThemeProgressBarBg}
\setbeamercolor{title separator}{fg=NoumanityOrange}
\setbeamercolor{alerted text}{fg=NoumanityOrange}
\setbeamercolor{structure}{fg=NoumanityOrange}
\setbeamercolor{item}{fg=NoumanityOrange}
\setbeamercolor{subitem}{fg=NouThemeSubitemFg}
\setbeamercolor{block title}{bg=NoumanityOrange, fg=NoumanityWhite}
\setbeamercolor{block body}{bg=NouThemeBlockBodyBg}

% Polices de marque via fontspec (LuaLaTeX)
% ABeeZee = titres et emphases fortes ; Arimo = corps (Google Fonts libres)
% IfFontExistsTF : charge la police si disponible, repli silencieux sinon.
\IfFontExistsTF{\NouThemeBodyFont}{%
  \setsansfont{\NouThemeBodyFont}[
    BoldFont = \NouThemeBodyBoldFont,
    ItalicFont = \NouThemeBodyItalicFont,
    BoldItalicFont = \NouThemeBodyBoldItalicFont
  ]
  \setmainfont{\NouThemeBodyFont}
}{}
\IfFontExistsTF{\NouThemeTitleFont}{%
  \newfontfamily\NouTitleFont{\NouThemeTitleFont}%
  \setbeamerfont{title}{family={\fontspec{\NouThemeTitleFont}}, size=\NouThemeTitleSize}
  \setbeamerfont{frametitle}{family={\fontspec{\NouThemeTitleFont}}, size=\NouThemeFrameTitleSize}
}{%
  \newcommand\NouTitleFont{}%
}

% Listes : puces avec couleur de marque
\setbeamertemplate{itemize item}{\textcolor{NoumanityOrange}{\NouThemeItemSymbol}}
\setbeamertemplate{itemize subitem}{\textcolor{NouThemeSubitemFg}{\NouThemeSubitemSymbol}}

\mode<all>
