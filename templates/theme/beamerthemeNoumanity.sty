% beamerthemeNoumanity.sty - Theme Beamer Noumanity, extension de metropolis
% Couleurs : branding.yml (orange #FA4D1F, noir #000000)
% Polices  : ABeeZee (titres) + Arimo (corps) si installes ; repli Latin Modern.
% Conforme ADR-001 : base metropolis, fontspec, LuaLaTeX.
\mode<presentation>

% Charger metropolis comme base
\usetheme{metropolis}

% Couleurs de marque (topologie : 2 couleurs + neutres techniques)
\definecolor{NoumanityOrange}{HTML}{FA4D1F}
\definecolor{NoumanityBlack}{HTML}{000000}
\definecolor{NoumanityWhite}{HTML}{FFFFFF}

% Surcharge de la palette metropolis
\setbeamercolor{frametitle}{bg=NoumanityOrange, fg=NoumanityWhite}
\setbeamercolor{progress bar}{fg=NoumanityOrange, bg=NoumanityBlack!25}
\setbeamercolor{title separator}{fg=NoumanityOrange}
\setbeamercolor{alerted text}{fg=NoumanityOrange}
\setbeamercolor{structure}{fg=NoumanityOrange}
\setbeamercolor{item}{fg=NoumanityOrange}
\setbeamercolor{subitem}{fg=NoumanityOrange!80}
\setbeamercolor{block title}{bg=NoumanityOrange, fg=NoumanityWhite}
\setbeamercolor{block body}{bg=NoumanityBlack!5}

% Polices de marque via fontspec (LuaLaTeX)
% ABeeZee = titres et emphases fortes ; Arimo = corps (Google Fonts libres)
% IfFontExistsTF : charge la police si disponible, repli silencieux sinon.
\IfFontExistsTF{Arimo}{%
  \setsansfont{Arimo}[
    BoldFont = Arimo Bold,
    ItalicFont = Arimo Italic,
    BoldItalicFont = Arimo Bold Italic
  ]
  \setmainfont{Arimo}
}{}
\IfFontExistsTF{ABeeZee}{%
  \setbeamerfont{title}{family={\fontspec{ABeeZee}}, size=\Large}
  \setbeamerfont{frametitle}{family={\fontspec{ABeeZee}}, size=\large}
}{}

% Listes : puces avec couleur de marque
\setbeamertemplate{itemize item}{\textcolor{NoumanityOrange}{\textbullet}}
\setbeamertemplate{itemize subitem}{\textcolor{NoumanityOrange!80}{\textendash}}

\mode<all>
